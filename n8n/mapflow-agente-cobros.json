    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000025",
      "name": "Enviar Email Deudor",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        1120,
        -160
      ],
      "onError": "continueErrorOutput",
      "parameters": {
        "fromEmail": "MapFlow Cobros <46moras@gmail.com>",
        "toEmail": "={{ $('Filtrar Ya Enviados').item.json.contacto?.email }}",
        "subject": "=Recordatorio de pago · Factura {{ $('Filtrar Ya Enviados').item.json.numero_factura }} · {{ $('Filtrar Ya Enviados').item.json.empresa?.nombre }}",
