      "name": "Filtrar Alertas Nuevas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        400
      ],
      "parameters": {
        "jsCode": "// Deja pasar solo las alertas que no se enviaron hoy\nconst enviados = new Set(\n  $input.all().map(i => (i.json || {}).huella_unica).filter(Boolean)\n);\nreturn $('Preparar Alertas').all().filter(i => !enviados.has(i.json.huella_unica));"
      }
