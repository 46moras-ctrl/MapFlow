    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000009",
      "name": "Preparar Consulta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        -560
      ],
      "parameters": {
        "jsCode": "// REGLA DE ORO: sin empresa identificada NO se responde nada.\nconst empresa = $input.first().json || {};\nconst ctx = $('Separar Ramas').first().json;\nif (!empresa.id) {\n  throw new Error('Empresa no encontrada para este usuario/canal. Acceso denegado (aislamiento por empresa).');\n}\nreturn [{ json: { ...ctx, id_empresa: empresa.id, nombre_empresa: empresa.nombre } }];"
      }
    },
    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000010",
