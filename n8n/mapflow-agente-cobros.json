    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000030",
      "name": "Preparar Alertas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        400
      ],
      "parameters": {
        "jsCode": "// Alerta al dueño por facturas con más de 5 días de atraso.\n// Se incluye estado 'pendiente' además de 'vencido' por si la app\n// aún no marcó la factura como vencida: la fecha manda.\nconst hoy = $now.toFormat('yyyy-MM-dd');\nconst out = [];\nfor (const item of $input.all()) {\n  const f = item.json;\n  const e = f.empresa || {};\n  if (!e.email_dueno && !e.telefono_dueno) continue; // el dueño no configuró contacto\n  const mora = Math.max(0, Math.round((Date.parse(hoy) - Date.parse(f.fecha_vencimiento)) / 86400000));\n  if (mora <= 5) continue; // regla: MÁS de 5 días de atraso\n  out.push({ json: { ...f, hoy, dias_mora: mora, huella_unica: 'alerta:' + f.id + ':' + hoy } });\n}\nreturn out;"
      }
    },
