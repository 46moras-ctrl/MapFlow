    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000020",
      "name": "Preparar Recordatorios",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        -80
      ],
      "parameters": {
        "jsCode": "// Un recordatorio por factura. La huella evita repetir el mismo día.\n// AISLAMIENTO: cada item lleva SOLO los datos de su propia factura,\n// contacto y empresa (vía FK); nunca se mezclan empresas.\nconst hoy = $now.toFormat('yyyy-MM-dd');\nconst out = [];\nfor (const item of $input.all()) {\n  const f = item.json;\n  const c = f.contacto || {};\n  if (!c.email && !c.telefono) continue; // sin datos de contacto no hay envío\n  const mora = Math.max(0, Math.round((Date.parse(hoy) - Date.parse(f.fecha_vencimiento)) / 86400000));\n  out.push({ json: { ...f, hoy, dias_mora: mora, huella_unica: 'rec:' + f.id + ':' + hoy } });\n}\nreturn out;"
      }
    },
    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000021",
      "name": "Verificar Enviados Hoy",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        -80
      ],
      "executeOnce": true,
      "alwaysOutputData": true,
      "parameters": {
        "method": "GET",
        "url": "=https://qnsuaycfryruebclgavv.supabase.co/rest/v1/mensajes_agente?select=huella_unica&estado_envio=eq.enviado&huella_unica=in.({{ $('Preparar Recordatorios').all().map(i => '\"' + i.json.huella_unica + '\"').join(',') }})",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "options": {}
