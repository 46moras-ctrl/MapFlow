    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000004",
      "name": "Normalizar Telegram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        -560
      ],
      "parameters": {
        "jsCode": "// Normaliza la entrada de Telegram para el Switch\nconst out = [];\nfor (const item of $input.all()) {\n  const msg = item.json.message || {};\n  out.push({ json: {\n    rama: 'consulta_interna',\n    origen: 'telegram',\n    texto: msg.text || '',\n    telegram_chat_id: String((msg.chat && msg.chat.id) || ''),\n    usuario: (msg.from && msg.from.username) || ''\n  }});\n}\nreturn out;"
      }
    },
    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000005",
      "name": "Normalizar Chat Web",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        -320
      ],
      "parameters": {
        "jsCode": "// El chat de la web de MapFlow manda: { id_empresa, mensaje }\nconst out = [];\nfor (const item of $input.all()) {\n  const b = item.json.body || item.json;\n  out.push({ json: {\n    rama: 'consulta_interna',\n    origen: 'chat_plataforma',\n    texto: b.mensaje || b.message || '',\n    id_empresa: b.id_empresa || null\n  }});\n}\nreturn out;"
      }
    },
    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000006",
      "name": "Preparar Ciclos Diarios",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        -80
      ],
      "parameters": {
        "jsCode": "// Un solo disparo del cron alimenta las ramas 2 y 3:\n// el Switch enruta cada item a su rama.\nconst hoy = $now.toFormat('yyyy-MM-dd');\nreturn [\n  { json: { rama: 'recordatorio_deudor', hoy } },\n  { json: { rama: 'alerta_dueno', hoy } }\n];"
      }
    },
