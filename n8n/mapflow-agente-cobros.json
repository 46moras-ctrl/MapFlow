        "supabaseApi": {
          "name": "MapFlow Supabase"
        }
      }
    },
    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000022",
      "name": "Filtrar Ya Enviados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        -80
      ],
      "parameters": {
        "jsCode": "// Deja pasar solo las facturas cuyo recordatorio de HOY no existe aún\n// (anti-duplicación, regla de oro #1; el índice único de la tabla es el respaldo)\nconst enviados = new Set(\n  $input.all().map(i => (i.json || {}).huella_unica).filter(Boolean)\n);\nreturn $('Preparar Recordatorios').all().filter(i => !enviados.has(i.json.huella_unica));"
      }
    },
    {
      "id": "9f2b6a1e-0d3c-4f5a-8b1e-100000000023",
      "name": "Redactar Recordatorio",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.5,
      "position": [
        880,
        -80
      ],
      "parameters": {
        "promptType": "define",
        "text": "=Redacta un recordatorio de pago para un cliente. Tono CORDIAL y profesional, en español, máximo 120 palabras, sin amenazas.\n\nUsa ÚNICAMENTE estos datos (no agregues ni inventes nada más):\n- Cliente: {{ $json.contacto?.nombre || $json.cliente }}\n- Factura: {{ $json.numero_factura }}{{ $json.concepto ? ' (' + $json.concepto + ')' : '' }}\n- Monto: {{ $json.monto }}\n- Fecha de vencimiento: {{ $json.fecha_vencimiento }}\n- Días de atraso: {{ $json.dias_mora }}\n- Empresa que cobra: {{ $json.empresa?.nombre }}\n\nSi los días de atraso son 0, es un aviso amable de próximo vencimiento. Cierra indicando que abajo está el botón con la información para pagar. Devuelve SOLO el texto del mensaje, sin asunto y sin comillas.",
        "options": {}
      }
    },
